const TARGET_GGT: Text = "GGT";
const TARGET_GGTA: Text = "GGTA";
const TARGET_GGTATT: Text = "GGTATT";
const TARGET_GGTATTTTAATT: Text = "GGTATTTTAATT";
const TARGET_GGTATTTTAATTTATAGT: Text = "GGTATTTTAATTTATAGT";

fn find_line_end(source: Text, start: I32) -> I32 {
    if start >= text_len(source) {
        start
    } else {
        if text_byte(source, start) == 10 {
            start
        } else {
            find_line_end(source, start + 1)
        }
    }
}

fn trim_line_end(source: Text, end: I32) -> I32 {
    if end > 0 and text_byte(source, end - 1) == 13 {
        end - 1
    } else {
        end
    }
}

fn line_is_three_header(line: Text) -> Bool {
    text_len(line) >= 6 and
        text_byte(line, 0) == 62 and
        text_byte(line, 1) == 84 and
        text_byte(line, 2) == 72 and
        text_byte(line, 3) == 82 and
        text_byte(line, 4) == 69 and
        text_byte(line, 5) == 69
}

fn encode_base(byte: I32) -> I32 {
    if byte == 65 or byte == 97 {
        0
    } else {
        if byte == 67 or byte == 99 {
            1
        } else {
            if byte == 71 or byte == 103 {
                2
            } else {
                if byte == 84 or byte == 116 {
                    3
                } else {
                    -1
                }
            }
        }
    }
}

fn base_codepoint(code: I32) -> I32 {
    if code == 0 {
        65
    } else {
        if code == 1 {
            67
        } else {
            if code == 2 {
                71
            } else {
                84
            }
        }
    }
}

fn append_code_kmer(builder: TextBuilder, code: I32, len: I32) -> TextBuilder {
    if len == 1 {
        text_builder_append_codepoint(builder, base_codepoint(code))
    } else {
        let first = code / 4;
        let second = code - first * 4;
        let after_first = text_builder_append_codepoint(builder, base_codepoint(first));
        text_builder_append_codepoint(after_first, base_codepoint(second))
    }
}

fn append_percent_line(builder: TextBuilder, code: I32, len: I32, count: I32, total: I32) -> TextBuilder {
    let with_key = append_code_kmer(builder, code, len);
    let with_space = text_builder_append_codepoint(with_key, 32);
    let ratio = 100.0 * f64_from_i32(count) / f64_from_i32(total);
    let with_value = text_builder_append(with_space, text_from_f64_fixed(ratio, 3));
    text_builder_append_codepoint(with_value, 10)
}

fn append_count_line(builder: TextBuilder, count: I32, label: Text) -> TextBuilder {
    let with_count = text_builder_append(builder, text_from_f64_fixed(f64_from_i32(count), 0));
    let with_tab = text_builder_append_codepoint(with_count, 9);
    let with_label = text_builder_append(with_tab, label);
    text_builder_append_codepoint(with_label, 10)
}

fn append_count_line_final(builder: TextBuilder, count: I32, label: Text) -> TextBuilder {
    let with_count = text_builder_append(builder, text_from_f64_fixed(f64_from_i32(count), 0));
    let with_tab = text_builder_append_codepoint(with_count, 9);
    text_builder_append(with_tab, label)
}

fn append_sorted_percent_lines_1(builder: TextBuilder, counts: List[I32], total: I32) -> TextBuilder {
    let mut current = builder;
    let mut used = list_new(4, false);
    repeat step in 4 {
        let mut best = -1;
        let mut best_count = -1;
        repeat i in 4 {
            let count = list_get(counts, i);
            if not (list_get(used, i)) and (best == -1 or count > best_count or (count == best_count and i < best)) {
                best = i;
                best_count = count;
            };
        };
        used = list_set(used, best, true);
        current = append_percent_line(current, best, 1, list_get(counts, best), total);
    };
    current
}

fn append_sorted_percent_lines_2(builder: TextBuilder, counts: List[I32], total: I32) -> TextBuilder {
    let mut current = builder;
    let mut used = list_new(16, false);
    repeat step in 16 {
        let mut best = -1;
        let mut best_count = -1;
        repeat i in 16 {
            let count = list_get(counts, i);
            if not (list_get(used, i)) and (best == -1 or count > best_count or (count == best_count and i < best)) {
                best = i;
                best_count = count;
            };
        };
        used = list_set(used, best, true);
        current = append_percent_line(current, best, 2, list_get(counts, best), total);
    };
    current
}

fn suffix_match_3(last18: List[I32]) -> Bool {
    list_get(last18, 15) == 2 and list_get(last18, 16) == 2 and list_get(last18, 17) == 3
}

fn suffix_match_4(last18: List[I32]) -> Bool {
    list_get(last18, 14) == 2 and
        list_get(last18, 15) == 2 and
        list_get(last18, 16) == 3 and
        list_get(last18, 17) == 0
}

fn suffix_match_6(last18: List[I32]) -> Bool {
    list_get(last18, 12) == 2 and
        list_get(last18, 13) == 2 and
        list_get(last18, 14) == 3 and
        list_get(last18, 15) == 0 and
        list_get(last18, 16) == 3 and
        list_get(last18, 17) == 3
}

fn suffix_match_12(last18: List[I32]) -> Bool {
    list_get(last18, 6) == 2 and
        list_get(last18, 7) == 2 and
        list_get(last18, 8) == 3 and
        list_get(last18, 9) == 0 and
        list_get(last18, 10) == 3 and
        list_get(last18, 11) == 3 and
        list_get(last18, 12) == 3 and
        list_get(last18, 13) == 3 and
        list_get(last18, 14) == 0 and
        list_get(last18, 15) == 0 and
        list_get(last18, 16) == 3 and
        list_get(last18, 17) == 3
}

fn suffix_match_18(last18: List[I32]) -> Bool {
    list_get(last18, 0) == 2 and
        list_get(last18, 1) == 2 and
        list_get(last18, 2) == 3 and
        list_get(last18, 3) == 0 and
        list_get(last18, 4) == 3 and
        list_get(last18, 5) == 3 and
        list_get(last18, 6) == 3 and
        list_get(last18, 7) == 3 and
        list_get(last18, 8) == 0 and
        list_get(last18, 9) == 0 and
        list_get(last18, 10) == 3 and
        list_get(last18, 11) == 3 and
        list_get(last18, 12) == 3 and
        list_get(last18, 13) == 0 and
        list_get(last18, 14) == 3 and
        list_get(last18, 15) == 0 and
        list_get(last18, 16) == 2 and
        list_get(last18, 17) == 3
}

fn main() -> Text {
    let input = stdin_text();
    let mut counts1 = list_new(4, 0);
    let mut counts2 = list_new(16, 0);
    let mut last18 = list_new(18, 0);
    let mut total = 0;
    let mut rolling2 = 0;
    let mut in_three = false;
    let mut done = false;
    let mut index = 0;
    let mut count_ggt = 0;
    let mut count_ggta = 0;
    let mut count_ggtatt = 0;
    let mut count_ggtattttaatt = 0;
    let mut count_ggtattttaatttatagt = 0;
    while index < text_len(input) and not done {
        let line_end = find_line_end(input, index);
        let content_end = trim_line_end(input, line_end);
        let line = text_slice(input, index, content_end);
        if text_len(line) > 0 and text_byte(line, 0) == 62 {
            if in_three {
                done = true;
            } else {
                in_three = line_is_three_header(line);
            };
        } else {
            if in_three {
                let mut pos = 0;
                while pos < text_len(line) {
                    let code = encode_base(text_byte(line, pos));
                    if code >= 0 {
                        repeat i in 17 {
                            last18 = list_set(last18, i, list_get(last18, i + 1));
                        };
                        last18 = list_set(last18, 17, code);
                        counts1 = list_set(counts1, code, list_get(counts1, code) + 1);
                        total = total + 1;
                        if total >= 2 {
                            rolling2 = ((rolling2 * 4) - ((rolling2 / 4) * 16)) + code;
                            counts2 = list_set(counts2, rolling2, list_get(counts2, rolling2) + 1);
                        } else {
                            rolling2 = code;
                        };
                        if total >= 3 and suffix_match_3(last18) {
                            count_ggt = count_ggt + 1;
                        };
                        if total >= 4 and suffix_match_4(last18) {
                            count_ggta = count_ggta + 1;
                        };
                        if total >= 6 and suffix_match_6(last18) {
                            count_ggtatt = count_ggtatt + 1;
                        };
                        if total >= 12 and suffix_match_12(last18) {
                            count_ggtattttaatt = count_ggtattttaatt + 1;
                        };
                        if total >= 18 and suffix_match_18(last18) {
                            count_ggtattttaatttatagt = count_ggtattttaatttatagt + 1;
                        };
                    };
                    pos = pos + 1;
                };
            };
        };
        if line_end < text_len(input) {
            index = line_end + 1;
        } else {
            index = line_end;
        };
    };

    let mut builder = text_builder_new();
    builder = append_sorted_percent_lines_1(builder, counts1, total);
    builder = text_builder_append_codepoint(builder, 10);
    builder = append_sorted_percent_lines_2(builder, counts2, total - 1);
    builder = text_builder_append_codepoint(builder, 10);
    builder = append_count_line(builder, count_ggt, TARGET_GGT);
    builder = append_count_line(builder, count_ggta, TARGET_GGTA);
    builder = append_count_line(builder, count_ggtatt, TARGET_GGTATT);
    builder = append_count_line(builder, count_ggtattttaatt, TARGET_GGTATTTTAATT);
    builder = append_count_line_final(builder, count_ggtattttaatttatagt, TARGET_GGTATTTTAATTTATAGT);
    text_builder_finish(builder)
}

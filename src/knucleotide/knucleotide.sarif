const TARGET_GGT: Text = "GGT";
const TARGET_GGTA: Text = "GGTA";
const TARGET_GGTATT: Text = "GGTATT";
const TARGET_GGTATTTTAATT: Text = "GGTATTTTAATT";
const TARGET_GGTATTTTAATTTATAGT: Text = "GGTATTTTAATTTATAGT";
const CODE_GGT: I32 = 43;
const CODE_GGTA: I32 = 172;
const CODE_GGTATT: I32 = 2767;
const CODE_GGTATTTTAATT: I32 = 11337487;
const CODE_GGTATTTTA_HI9: I32 = 177148;
const CODE_GGTATTTTA_LO9: I32 = 64715;
const POW2: I32 = 16;
const POW6: I32 = 4096;
const POW9: I32 = 262144;
const POW12: I32 = 16777216;
const DIV2: I32 = 4;
const DIV6: I32 = 1024;
const DIV9: I32 = 65536;
const DIV12: I32 = 4194304;

fn trim_line_end(source: Text, end: I32) -> I32 {
    if end > 0 and text_byte(source, end - 1) == 13 {
        end - 1
    } else {
        end
    }
}

fn line_is_three_header(source: Text, start: I32, end: I32) -> Bool {
    end - start >= 6 and
        text_byte(source, start) == 62 and
        text_eq_range(source, start + 1, start + 6, "THREE")
}

fn encode_base(byte: I32) -> I32 {
    if byte == 65 or byte == 97 {
        0
    } else {
        if byte == 67 or byte == 99 {
            1
        } else {
            if byte == 71 or byte == 103 {
                2
            } else {
                if byte == 84 or byte == 116 {
                    3
                } else {
                    -1
                }
            }
        }
    }
}

fn base_codepoint(code: I32) -> I32 {
    if code == 0 {
        65
    } else {
        if code == 1 {
            67
        } else {
            if code == 2 {
                71
            } else {
                84
            }
        }
    }
}

fn append_code_kmer(builder: TextBuilder, code: I32, len: I32) -> TextBuilder {
    if len == 1 {
        text_builder_append_codepoint(builder, base_codepoint(code))
    } else {
        let first = code / 4;
        let second = code - first * 4;
        let after_first = text_builder_append_codepoint(builder, base_codepoint(first));
        text_builder_append_codepoint(after_first, base_codepoint(second))
    }
}

fn append_percent_line(builder: TextBuilder, code: I32, len: I32, count: I32, total: I32) -> TextBuilder {
    let mut current = append_code_kmer(builder, code, len);
    current += " ";
    let ratio = 100.0 * f64_from_i32(count) / f64_from_i32(total);
    current += text_from_f64_fixed(ratio, 3);
    current += "\n";
    current
}

fn append_count_line(builder: TextBuilder, count: I32, label: Text) -> TextBuilder {
    let mut current = builder;
    current += count;
    current += "	";
    current += label;
    current += "\n";
    current
}

fn append_count_line_final(builder: TextBuilder, count: I32, label: Text) -> TextBuilder {
    let mut current = builder;
    current += count;
    current += "	";
    current += label;
    current
}

fn append_sorted_percent_lines_1(builder: TextBuilder, counts: List[I32], total: I32) -> TextBuilder effects [alloc] {
    let mut current = builder;
    let mut used = list_new(4, false);
    repeat step in 4 {
        let mut best = -1;
        let mut best_count = -1;
        repeat i in 4 {
            let count = counts[i];
            if not (used[i]) and (best == -1 or count > best_count or (count == best_count and i < best)) {
                best = i;
                best_count = count;
            };
        };
        used[best] = true;
        current = append_percent_line(current, best, 1, counts[best], total);
    };
    current
}

fn append_sorted_percent_lines_2(builder: TextBuilder, counts: List[I32], total: I32) -> TextBuilder effects [alloc] {
    let mut current = builder;
    let mut used = list_new(16, false);
    repeat step in 16 {
        let mut best = -1;
        let mut best_count = -1;
        repeat i in 16 {
            let count = counts[i];
            if not (used[i]) and (best == -1 or count > best_count or (count == best_count and i < best)) {
                best = i;
                best_count = count;
            };
        };
        used[best] = true;
        current = append_percent_line(current, best, 2, counts[best], total);
    };
    current
}

fn main() -> Text effects [alloc] {
    let input = stdin_text();
    let mut counts1 = list_new(4, 0);
    let mut counts2 = list_new(16, 0);
    let mut lag9 = list_new(9, 0);
    let mut total = 0;
    let mut rolling2 = 0;
    let mut rolling6 = 0;
    let mut rolling9 = 0;
    let mut rolling12 = 0;
    let mut lag9_index = 0;
    let mut in_three = false;
    let mut done = false;
    let mut index = 0;
    let mut count_ggt = 0;
    let mut count_ggta = 0;
    let mut count_ggtatt = 0;
    let mut count_ggtattttaatt = 0;
    let mut count_ggtattttaatttatagt = 0;
    while index < input.len and not done {
        let line_end = text_find_byte_range(input, index, input.len, 10);
        let content_end = trim_line_end(input, line_end);
        if content_end > index and text_byte(input, index) == 62 {
            if in_three {
                done = true;
            } else {
                in_three = line_is_three_header(input, index, content_end);
            };
        } else {
            if in_three {
                let mut pos = index;
                while pos < content_end {
                    let code = encode_base(text_byte(input, pos));
                    if code >= 0 {
                        counts1[code] = counts1[code] + 1;
                        total = total + 1;
                        if total >= 2 {
                            rolling2 = ((rolling2 * 4) - ((rolling2 / DIV2) * POW2)) + code;
                            counts2[rolling2] = counts2[rolling2] + 1;
                        } else {
                            rolling2 = code;
                        };
                        if total >= 6 {
                            rolling6 = ((rolling6 * 4) - ((rolling6 / DIV6) * POW6)) + code;
                        } else {
                            rolling6 = rolling6 * 4 + code;
                        };
                        if total >= 9 {
                            rolling9 = ((rolling9 * 4) - ((rolling9 / DIV9) * POW9)) + code;
                        } else {
                            rolling9 = rolling9 * 4 + code;
                        };
                        if total >= 12 {
                            rolling12 = ((rolling12 * 4) - ((rolling12 / DIV12) * POW12)) + code;
                        } else {
                            rolling12 = rolling12 * 4 + code;
                        };
                        if total >= 3 and (rolling6 - ((rolling6 / 64) * 64)) == CODE_GGT {
                            count_ggt = count_ggt + 1;
                        };
                        if total >= 4 and (rolling6 - ((rolling6 / 256) * 256)) == CODE_GGTA {
                            count_ggta = count_ggta + 1;
                        };
                        if total >= 6 and rolling6 == CODE_GGTATT {
                            count_ggtatt = count_ggtatt + 1;
                        };
                        if total >= 12 and rolling12 == CODE_GGTATTTTAATT {
                            count_ggtattttaatt = count_ggtattttaatt + 1;
                        };
                        if total >= 9 {
                            let high9 = lag9[lag9_index];
                            lag9[lag9_index] = rolling9;
                            lag9_index = lag9_index + 1;
                            if lag9_index == 9 {
                                lag9_index = 0;
                            };
                            if total >= 18 and high9 == CODE_GGTATTTTA_HI9 and rolling9 == CODE_GGTATTTTA_LO9 {
                                count_ggtattttaatttatagt = count_ggtattttaatttatagt + 1;
                            };
                        };
                    };
                    pos = pos + 1;
                };
            };
        };
        if line_end < input.len {
            index = line_end + 1;
        } else {
            index = line_end;
        };
    };

    let mut builder = text_builder_new();
    builder = append_sorted_percent_lines_1(builder, counts1, total);
    builder += "\n";
    builder = append_sorted_percent_lines_2(builder, counts2, total - 1);
    builder += "\n";
    builder = append_count_line(builder, count_ggt, TARGET_GGT);
    builder = append_count_line(builder, count_ggta, TARGET_GGTA);
    builder = append_count_line(builder, count_ggtatt, TARGET_GGTATT);
    builder = append_count_line(builder, count_ggtattttaatt, TARGET_GGTATTTTAATT);
    builder = append_count_line_final(builder, count_ggtattttaatttatagt, TARGET_GGTATTTTAATTTATAGT);
    text_builder_finish(builder)
}

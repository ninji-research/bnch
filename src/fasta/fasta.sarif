const WIDTH:I32=60;const CHUNK_LINES:I32=4096;const IM:I32=139968;const IA:I32=3877;const IC:I32=29573;const ALU:Text="GGCCGGGCGCGGTGGCTCACGCCTGTAATCCCAGCACTTTGGGAGGCCGAGGCGGGCGGATCACCTGAGGTCAGGAGTTCGAGACCAGCCTGGCCAACATGGTGAAACCCCGTCTCTACTAAAAATACAAAAATTAGCCGGGCGTGGTGGCGCGCGCCTGTAATCCCAGCTACTCGGGAGGCTGAGGCAGGAGAATCGCTTGAACCCGGGAGGCGGAGGTTGCAGTGAGCCGAGATCGCGCCACTGCACTCCAGCCTGGGCGACAGAGCGAGACTCCGTCTCAAAAA";fn next_seed(seed:I32)->I32{let value=seed*IA+IC;value-(value/IM)*IM}fn pick_iub_codepoint(seed:I32)->I32{match seed{0..37792=>{97},37792..54588=>{99},54588..71384=>{103},71384..109176=>{116},109176..111975=>{66},111975..114774=>{68},114774..117574=>{72},117574..120373=>{75},120373..123172=>{77},123172..125972=>{78},125972..128771=>{82},128771..131570=>{83},131570..134370=>{86},134370..137169=>{87},_=>{89},}}fn pick_homo_codepoint(seed:I32)->I32{match seed{0..42404=>{97},42404..70117=>{99},70117..97767=>{103},_=>{116},}}fn write_repeat_section(header:Text,source:Text,length:I32)effects[alloc]{stdout_write(header);stdout_write("\n");let source_len=text_len(source);let mut chunk=text_builder_new();let mut chunk_lines=0;let mut offset=0;let mut remaining=length;while remaining>0{let line_len=if remaining<WIDTH{remaining}else{WIDTH};let end=offset+line_len;if end<=source_len{chunk=text_builder_append_slice(chunk,source,offset,end);}else{chunk=text_builder_append_slice(chunk,source,offset,source_len);chunk=text_builder_append_slice(chunk,source,0,end-source_len);};chunk=text_builder_append_ascii(chunk,10);chunk_lines+=1;if chunk_lines==CHUNK_LINES{chunk=stdout_write_builder(chunk);chunk_lines=0;};let next_offset=offset+line_len;offset=next_offset-(next_offset/source_len)*source_len;remaining-=line_len;};stdout_write_builder(chunk);}fn write_random_section(seed:I32,header:Text,length:I32,use_homo:Bool)->I32 effects[alloc]{stdout_write(header);stdout_write("\n");let mut current_seed=seed;let mut chunk=text_builder_new();let mut chunk_lines=0;let mut remaining=length;while remaining>0{let line_len=if remaining<WIDTH{remaining}else{WIDTH};let mut i=0;while i<line_len{current_seed=next_seed(current_seed);chunk=text_builder_append_ascii(chunk,if use_homo{pick_homo_codepoint(current_seed)}else{pick_iub_codepoint(current_seed)},);i+=1;};chunk=text_builder_append_ascii(chunk,10);chunk_lines+=1;if chunk_lines==CHUNK_LINES{chunk=stdout_write_builder(chunk);chunk_lines=0;};remaining-=line_len;};stdout_write_builder(chunk);current_seed}fn main()effects[alloc]{let n=if arg_count()>1{parse_i32(arg_text(1))}else{250000};write_repeat_section(">ONE Homo sapiens alu",ALU,n*2);let iub_seed=write_random_section(42,">TWO IUB ambiguity codes",n*3,false);write_random_section(iub_seed,">THREE Homo sapiens frequency",n*5,true);}

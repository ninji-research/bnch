const WIDTH:I32=60;const CHUNK_LINES:I32=256;fn complement_ascii(byte:I32)->I32{match byte{65|97=>{84},67|99=>{71},71|103=>{67},84|116|85|117=>{65},77|109=>{75},82|114=>{89},87|119=>{87},83|115=>{83},89|121=>{82},75|107=>{77},86|118=>{66},72|104=>{68},68|100=>{72},66|98=>{86},_=>{78},}}fn flush_record(source:Text,header_start:I32,header_end:I32,seq_start:I32,seq_end:I32,)effects[alloc]{if header_end>header_start{let mut builder=text_builder_new();builder=text_builder_append_slice(builder,source,header_start,header_end);builder=text_builder_append_ascii(builder,10);let mut chunk_lines=0;let mut line_len=0;let mut index=seq_end;while index>seq_start{index=index-1;let byte=text_byte(source,index);if byte!=10 and byte!=13{builder=text_builder_append_ascii(builder,complement_ascii(byte));line_len=line_len+1;if line_len==WIDTH{builder=text_builder_append_ascii(builder,10);chunk_lines=chunk_lines+1;if chunk_lines==CHUNK_LINES{builder=stdout_write_builder(builder);chunk_lines=0;};line_len=0;};};};if line_len>0{builder=text_builder_append_ascii(builder,10);};stdout_write_builder(builder);};}fn main()effects[alloc]{let input=stdin_text();let mut header_start=0;let mut header_end=0;let mut seq_start=0;let mut index=0;while index<input.len{let line_end=text_next_line(input,index);let content_end=text_line_end(input,index);if content_end>index and text_byte(input,index)==62{flush_record(input,header_start,header_end,seq_start,index);header_start=index;header_end=content_end;seq_start=line_end;};index=line_end;};flush_record(input,header_start,header_end,seq_start,input.len);}

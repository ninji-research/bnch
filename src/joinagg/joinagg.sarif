struct UserRow{key:Text}struct AggregateRow{key:Text,count:I32,latency_sum:I32,bytes_sum:I32}struct AggregateList{rows:List[AggregateRow],len:I32}struct RowCuts{comma1:I32,comma2:I32,comma3:I32}fn scan_row_cuts(source:Text,start:I32,end:I32)->RowCuts{let comma1=text_find_byte_range(source,start,end,44);let comma2=text_find_byte_range(source,comma1+1,end,44);RowCuts{comma1,comma2,comma3:text_find_byte_range(source,comma2+1,end,44),}}fn user_is_active(source:Text,cuts:RowCuts,end:I32)->Bool{text_eq_range(source,cuts.comma3+1,end,"active")}fn event_is_live(source:Text,cuts:RowCuts)->Bool{not text_eq_range(source,cuts.comma1+1,cuts.comma2,"noop")}fn aggregate_key(region:Text,tier:Text)->Text effects[alloc]{let mut builder=text_builder_new();builder+=region;builder=text_builder_append_ascii(builder,9);builder+=tier;text_builder_finish(builder)}fn aggregate_join(input:Text)->AggregateList effects[alloc]{let empty_user=UserRow{key:""};let mut users=list_new(8,empty_user);let mut user_len=0;let mut user_index=text_index_new();let empty_aggregate=AggregateRow{key:"",count:0,latency_sum:0,bytes_sum:0,};let mut rows=list_new(8,empty_aggregate);let mut len=0;let mut aggregates=text_index_new();let mut section=0;let mut skip_header=false;let mut index=0;while index<input.len{let content_end=text_line_end(input,index);if content_end>index{if text_eq_range(input,index,content_end,"[users]"){section=1;skip_header=true;}else if text_eq_range(input,index,content_end,"[events]"){section=2;skip_header=true;}else if skip_header{skip_header=false;}else if section==1{let cuts=scan_row_cuts(input,index,content_end);if user_is_active(input,cuts,content_end){let user_id=text_slice(input,index,cuts.comma1);user_index=text_index_set(user_index,user_id,user_len);users=list_push(users,user_len,UserRow{key:aggregate_key(text_slice(input,cuts.comma1+1,cuts.comma2),text_slice(input,cuts.comma2+1,cuts.comma3),),});user_len+=1;}}else if section==2{let cuts=scan_row_cuts(input,index,content_end);if event_is_live(input,cuts){let user_pos=text_index_get(user_index,text_slice(input,index,cuts.comma1));if user_pos>=0{let user=users[user_pos];let latency_ms=parse_i32_range(input,cuts.comma2+1,cuts.comma3);let bytes=parse_i32_range(input,cuts.comma3+1,content_end);let pos=text_index_get_or_insert(aggregates,user.key,len);if pos==len{rows=list_push(rows,len,AggregateRow{key:user.key,count:1,latency_sum:latency_ms,bytes_sum:bytes});len+=1;}else{let current=rows[pos];rows[pos]=AggregateRow{key:current.key,count:current.count+1,latency_sum:current.latency_sum+latency_ms,bytes_sum:current.bytes_sum+bytes};}}}}};index=text_next_line(input,index);};AggregateList{rows,len}}fn main()->Text effects[alloc]{let data=aggregate_join(stdin_text());let rows=list_sort_by_text_field(data.rows,data.len,"key");let mut builder=text_builder_new();let mut index=0;while index<data.len{let row=rows[index];let tab=text_find_byte_range(row.key,0,row.key.len,9);builder+=text_slice(row.key,0,tab);builder+=",";builder+=text_slice(row.key,tab+1,row.key.len);builder+=",";builder+=row.count;builder+=",";builder+=row.latency_sum;builder+=",";builder+=row.bytes_sum;index+=1;if index<data.len{builder+="\n";};};text_builder_finish(builder)}
